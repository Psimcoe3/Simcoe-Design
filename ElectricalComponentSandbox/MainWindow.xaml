<Window x:Class="ElectricalComponentSandbox.MainWindow"
    x:Name="RootWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:ElectricalComponentSandbox"
    xmlns:converters="clr-namespace:ElectricalComponentSandbox.Converters"
    xmlns:rendering="clr-namespace:ElectricalComponentSandbox.Rendering"
    xmlns:viewModels="clr-namespace:ElectricalComponentSandbox.ViewModels"
    xmlns:h="http://helix-toolkit.org/wpf"
    mc:Ignorable="d"
    Icon="app.ico"
    Title="Electrical Component Sandbox" Height="800" Width="1400"
    WindowState="Maximized"
    KeyDown="Window_KeyDown">
    
<Window.Resources>
    <!-- Value Converters -->
    <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
    <converters:NotNullToVisibilityConverter x:Key="NotNullToVisibilityConverter"/>
    <SolidColorBrush x:Key="MobilePrimaryBrush" Color="#007AFF"/>
    <SolidColorBrush x:Key="MobileSurfaceBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="MobileSurfaceAltBrush" Color="#F2F2F7"/>
    <SolidColorBrush x:Key="MobileBorderBrush" Color="#C6C6C8"/>
    <SolidColorBrush x:Key="MobileMutedTextBrush" Color="#8E8E93"/>
    <SolidColorBrush x:Key="ShellSurfaceBrush" Color="#FFF7F8FA"/>
    <SolidColorBrush x:Key="ShellCardBrush" Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="ShellBorderBrush" Color="#FFD8DEE4"/>
    <SolidColorBrush x:Key="ShellPrimaryTextBrush" Color="#FF1F2933"/>
    <SolidColorBrush x:Key="ShellMutedTextBrush" Color="#FF52606D"/>
        
        <Style TargetType="Button">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="10,5"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Margin" Value="5"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="5"/>
        </Style>
        <Style x:Key="ProjectBrowserTreeItemStyle" TargetType="TreeViewItem">
            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
            <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
        </Style>
        <HierarchicalDataTemplate DataType="{x:Type viewModels:ProjectBrowserSheetItemViewModel}" ItemsSource="{Binding Children}">
            <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"/>
        </HierarchicalDataTemplate>
        <DataTemplate DataType="{x:Type viewModels:ProjectBrowserNamedViewItemViewModel}">
            <TextBlock Text="{Binding DisplayName}" Margin="2,0,0,0"/>
        </DataTemplate>
        <Style x:Key="MobileTopActionButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Height" Value="44"/>
            <Setter Property="MinWidth" Value="44"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{StaticResource MobilePrimaryBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style x:Key="MobileNavButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Height" Value="60"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Padding" Value="8,8"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource MobileMutedTextBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style x:Key="QuickActionButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="Background" Value="{StaticResource ShellCardBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource ShellBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style x:Key="CommandSurfaceCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource ShellCardBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource ShellBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="Padding" Value="10"/>
        </Style>
        <Style x:Key="CommandSurfaceHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource ShellMutedTextBrush}"/>
            <Setter Property="Margin" Value="0"/>
        </Style>
        <Style x:Key="InspectorHeaderCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource ShellSurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource ShellBorderBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="12,10"/>
        </Style>
        <Style x:Key="InspectorModeButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Background" Value="{StaticResource ShellCardBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource ShellBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style x:Key="InspectorTaskCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource ShellCardBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource ShellBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="10"/>
        </Style>
        <Style x:Key="InspectorTaskActionButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Margin" Value="0,8,8,0"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
        <Style x:Key="CanvasGuidanceCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#F7FFFFFF"/>
            <Setter Property="BorderBrush" Value="{StaticResource ShellBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="MaxWidth" Value="400"/>
        </Style>
        <Style x:Key="CanvasGuidanceTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource ShellPrimaryTextBrush}"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <Style x:Key="CanvasGuidanceBodyStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource ShellMutedTextBrush}"/>
            <Setter Property="Margin" Value="0,6,0,0"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <Style x:Key="CanvasGuidanceActionButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Margin" Value="0,8,8,0"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
    </Window.Resources>
    
    <DockPanel>
        <!-- Top Menu -->
        <Menu x:Name="TopMenu" DockPanel.Dock="Top">
            <MenuItem Header="File">
                <MenuItem Header="New Project" Click="NewProject_Click" InputGestureText="Ctrl+N"/>
                <MenuItem Header="Open Project..." Click="OpenProject_Click" InputGestureText="Ctrl+O"/>
                <MenuItem Header="Save Project" Click="SaveProject_Click" InputGestureText="Ctrl+S"/>
                <MenuItem Header="Save Project As..." Click="SaveProjectAs_Click" InputGestureText="Ctrl+Shift+S"/>
                <Separator/>
                <MenuItem Header="Import">
                    <MenuItem Header="Import PDF Underlay..." Click="ImportPdf_Click"/>
                    <MenuItem Header="Import XFDF Markups..." Click="ImportXfdf_Click"/>
                </MenuItem>
                <MenuItem Header="Export">
                    <MenuItem Header="Export JSON..." Click="ExportJson_Click" InputGestureText="Ctrl+E"/>
                    <MenuItem Header="Export BOM CSV..." Click="ExportBomCsv_Click"/>
                    <MenuItem Header="Export IFC..." Click="ExportIfc_Click"/>
                    <MenuItem Header="Export Schedule (Excel)..." Click="ExportSchedule_Click"/>
                    <MenuItem Header="Export DXF (AutoCAD)..." Click="ExportScheduleDxf_Click"/>
                    <MenuItem Header="Export XFDF Markups..." Click="ExportXfdf_Click"/>
                </MenuItem>
                <MenuItem Header="Insert">
                    <MenuItem Header="Insert Schedule Table..." Click="InsertScheduleTable_Click"/>
                    <MenuItem Header="Insert Symbol Legend..." Click="InsertSymbolLegend_Click"/>
                    <MenuItem Header="Insert Title Block..." Click="InsertTitleBlock_Click"/>
                </MenuItem>
                <MenuItem Header="Output">
                    <MenuItem Header="Plot to Image..." Click="PlotToImage_Click"/>
                    <MenuItem Header="Plot Style (CTB)..." Click="PlotStyleManager_Click"/>
                    <MenuItem Header="Page Setup..." Click="PageSetup_Click"/>
                    <MenuItem Header="Print Preview..." Click="PrintPreview_Click"/>
                </MenuItem>
                <Separator/>
                <MenuItem Header="Run Revit Introspection..." Click="RunRevitIntrospection_Click"/>
                <Separator/>
                <MenuItem Header="Exit" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="Edit">
                <MenuItem Header="Undo" Click="Undo_Click" InputGestureText="Ctrl+Z"/>
                <MenuItem Header="Redo" Click="Redo_Click" InputGestureText="Ctrl+Y"/>
                <Separator/>
                <MenuItem Header="Clipboard &amp; Delete">
                    <MenuItem Header="Cut" Click="CutComponent_Click" InputGestureText="Ctrl+X"/>
                    <MenuItem Header="Copy" Click="CopyComponent_Click" InputGestureText="Ctrl+C"/>
                    <MenuItem Header="Paste" Click="PasteComponent_Click" InputGestureText="Ctrl+V"/>
                    <MenuItem Header="Paste in Place" Click="PasteInPlace_Click"/>
                    <Separator/>
                    <MenuItem Header="Delete Selected" Click="DeleteComponent_Click" InputGestureText="Delete"/>
                </MenuItem>
                <MenuItem Header="Markup Edit">
                    <MenuItem Header="Edit Selected Geometry..."
                              Click="EditSelectedMarkupGeometry_Click"
                              InputGestureText="Ctrl+Shift+G"
                              IsEnabled="{Binding MarkupTool.HasGeometryEditableSelection}"
                              ToolTip="{Binding MarkupTool.SelectedMarkupGeometryEditSummary}"/>
                    <MenuItem Header="Edit Selected Annotation Text..."
                              Click="EditSelectedStructuredMarkup_Click"
                              InputGestureText="F2"
                              IsEnabled="{Binding MarkupTool.HasTextEditableSelection}"
                              ToolTip="{Binding MarkupTool.SelectedMarkupTextEditSummary}"/>
                    <MenuItem Header="Edit Selected Appearance..."
                              Click="EditSelectedMarkupAppearance_Click"
                              InputGestureText="Ctrl+Shift+A"
                              IsEnabled="{Binding MarkupTool.HasAppearanceEditableSelection}"
                              ToolTip="{Binding MarkupTool.SelectedMarkupAppearanceEditSummary}"/>
                    <MenuItem Header="Insert Vertex"
                              Click="InsertSelectedMarkupVertex_Click"
                              IsEnabled="{Binding MarkupTool.HasPathVertexInsertCandidate}"
                              ToolTip="{Binding MarkupTool.SelectedMarkupPathInsertSummary}"/>
                    <MenuItem Header="Delete Active Vertex"
                              Click="DeleteSelectedMarkupVertex_Click"
                              IsEnabled="{Binding MarkupTool.HasPathVertexDeleteCandidate}"
                              ToolTip="{Binding MarkupTool.SelectedMarkupPathDeleteSummary}"/>
                </MenuItem>
                <MenuItem Header="Transform">
                    <MenuItem Header="Duplicate Selected" Click="DuplicateComponent_Click" InputGestureText="Ctrl+D"/>
                    <MenuItem Header="Move..." Click="MoveComponent_Click"/>
                    <MenuItem Header="Rotate..." Click="RotateComponent_Click"/>
                    <MenuItem Header="Mirror..." Click="MirrorComponent_Click"/>
                </MenuItem>
                <MenuItem Header="Array">
                    <MenuItem Header="Rectangular Array..." Click="RectangularArray_Click"/>
                    <MenuItem Header="Polar Array..." Click="PolarArray_Click"/>
                </MenuItem>
                <MenuItem Header="Selection">
                    <MenuItem Header="Select by Layer..." Click="SelectByLayer_Click"/>
                    <MenuItem Header="Select by Type..." Click="SelectByType_Click"/>
                    <MenuItem Header="Select Similar" Click="SelectSimilar_Click"/>
                    <MenuItem Header="Quick Select..." Click="QuickSelect_Click"/>
                </MenuItem>
                <MenuItem Header="Analyze Selection">
                    <MenuItem Header="Measure Distance" Click="MeasureDistance_Click"/>
                    <MenuItem Header="Measure Area" Click="MeasureArea_Click"/>
                </MenuItem>
                <Separator/>
                <MenuItem Header="Delete Last Bend Point" Click="DeleteLastBendPoint_Click"/>
                <MenuItem Header="Bulk Edit Properties..." Click="BulkEditProperties_Click"/>
            </MenuItem>
            <MenuItem Header="View">
                <MenuItem Header="Show Grid" IsCheckable="True" IsChecked="{Binding ShowGrid}"/>
                <MenuItem Header="Snap to Grid" IsCheckable="True" IsChecked="{Binding SnapToGrid}"/>
                <Separator/>
                <MenuItem x:Name="ShowLibraryPanelMenuItem" Header="Show Left Panel" IsCheckable="True" IsChecked="True" Click="ShowLibraryPanelMenuItem_Click"/>
                <MenuItem x:Name="ShowPropertiesPanelMenuItem" Header="Show Right Panel" IsCheckable="True" IsChecked="True" Click="ShowPropertiesPanelMenuItem_Click"/>
                <Separator/>
                <MenuItem Header="2D Plan View" Click="Show2DView_Click"/>
                <MenuItem Header="3D Viewport" Click="Show3DView_Click"/>
                <Separator/>
                <MenuItem Header="Visual Style">
                    <MenuItem x:Name="VisualStyleRealisticMenuItem" Header="Realistic" Click="VisualStyleRealistic_Click" IsCheckable="True" IsChecked="True"/>
                    <MenuItem x:Name="VisualStyleShadedMenuItem" Header="Shaded" Click="VisualStyleShaded_Click" IsCheckable="True"/>
                    <MenuItem x:Name="VisualStyleWireframeMenuItem" Header="Wireframe" Click="VisualStyleWireframe_Click" IsCheckable="True"/>
                    <MenuItem x:Name="VisualStyleHiddenLineMenuItem" Header="Hidden Line" Click="VisualStyleHiddenLine_Click" IsCheckable="True"/>
                </MenuItem>
                <MenuItem x:Name="BillboardLabelsMenuItem" Header="Component Labels (3D)" IsCheckable="True" IsChecked="False" Click="BillboardLabels_Click"/>
                <Separator/>
                <MenuItem Header="Named Views">
                    <MenuItem Header="Save Current View..." Click="SaveNamedView_Click"/>
                    <MenuItem Header="Manage Views..." Click="ManageNamedViews_Click"/>
                    <Separator/>
                    <MenuItem x:Name="NamedViewsListMenuItem" Header="(none saved)" IsEnabled="False"/>
                </MenuItem>
                <Separator/>
                <MenuItem Header="Zoom Extents" Click="ZoomExtents_Click" InputGestureText="Ctrl+Shift+E"/>
                <MenuItem Header="Zoom Selection" Click="ZoomSelection_Click"/>
                <MenuItem Header="Home View" Click="HomeView_Click" InputGestureText="Home"/>
                <Separator/>
                <MenuItem Header="Layer States">
                    <MenuItem Header="Save Layer State..." Click="SaveLayerState_Click"/>
                    <MenuItem Header="Restore Layer State..." Click="RestoreLayerState_Click"/>
                    <MenuItem Header="Delete Layer State..." Click="DeleteLayerState_Click"/>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="Tools">
                <MenuItem Header="Add Parts">
                    <MenuItem Header="Conduit" Click="AddConduit_Click"/>
                    <MenuItem Header="Box" Click="AddBox_Click"/>
                    <MenuItem Header="Panel" Click="AddPanel_Click"/>
                    <MenuItem Header="Support" Click="AddSupport_Click"/>
                    <MenuItem Header="Cable Tray" Click="AddCableTray_Click"/>
                    <MenuItem Header="Hanger" Click="AddHanger_Click"/>
                </MenuItem>
                <MenuItem Header="Route &amp; Sketch">
                    <MenuItem Header="Draw Conduit" Click="DrawConduit_Click"/>
                    <MenuItem Header="Edit Conduit Path" Click="ToggleEditConduitPath_Click"/>
                    <MenuItem Header="Sketch Line" Click="SketchLine_Click"/>
                    <MenuItem Header="Sketch Rectangle" Click="SketchRectangle_Click"/>
                    <MenuItem Header="Convert Sketch" Click="ConvertSketch_Click"/>
                    <MenuItem Header="Freehand Conduit" Click="FreehandConduit_Click"/>
                    <MenuItem Header="Offset Conduit..." Click="OffsetConduit_Click"/>
                    <MenuItem Header="Auto-Route" Click="AutoRoute_Click"/>
                </MenuItem>
                <MenuItem Header="Fabrication Output">
                    <MenuItem Header="Export Runs CSV" Click="ExportRunSchedule_Click"/>
                    <MenuItem Header="Export Conduit JSON" Click="ExportConduitJson_Click"/>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="Electrical">
                <MenuItem Header="Voltage Drop Calculator..." Click="VoltageDropCalc_Click"/>
                <MenuItem Header="Wire Size Recommendation..." Click="WireSizeCalc_Click"/>
                <Separator/>
                <MenuItem Header="Panel Load Summary..." Click="PanelLoadSummary_Click"/>
                <MenuItem Header="Rebuild Panel Schedules" Click="RebuildPanelSchedules_Click"/>
                <Separator/>
                <MenuItem Header="Add Circuit..." Click="AddCircuit_Click"/>
                <MenuItem Header="Edit Circuit..." Click="EditCircuit_Click"/>
                <MenuItem Header="Delete Circuit..." Click="DeleteCircuit_Click"/>
                <Separator/>
                <MenuItem Header="Conduit Fill Check..." Click="ConduitFillCheck_Click"/>
                <Separator/>
                <MenuItem Header="Run NEC Design Check..." Click="RunNecCheck_Click"/>
                <MenuItem Header="Export Electrical Report..." Click="ExportElectricalReport_Click"/>
            </MenuItem>
            <MenuItem x:Name="ReferencesMenuItem" Header="References"/>
            <MenuItem Header="Markup">
                <MenuItem Header="Add Annotation">
                    <MenuItem Header="Add Callout..." Click="AddCallout_Click"/>
                    <MenuItem Header="Add Leader Note..." Click="AddLeaderNote_Click"/>
                    <MenuItem Header="Add Parameter Tag..." Click="AddComponentParameterTag_Click"/>
                    <MenuItem Header="Add Revision Cloud..." Click="AddRevisionCloud_Click"/>
                    <MenuItem Header="Add Stamp..." Click="AddStamp_Click"/>
                </MenuItem>
                <MenuItem Header="Review Actions">
                    <MenuItem Header="Approve Selected" Click="ApproveMarkup_Click"/>
                    <MenuItem Header="Reject Selected" Click="RejectMarkup_Click"/>
                    <MenuItem Header="Resolve Selected" Click="ResolveMarkup_Click"/>
                    <MenuItem Header="Assign Selected..." Click="AssignSelectedMarkup_Click"/>
                    <MenuItem Header="Assign Visible..." Click="AssignVisibleMarkups_Click"/>
                    <MenuItem Header="Reply To Selected..." Click="AddMarkupReply_Click"/>
                </MenuItem>
                <MenuItem Header="Markup Summary..." Click="MarkupSummary_Click"/>
            </MenuItem>
        </Menu>
        
        <!-- Desktop command surface -->
        <Border x:Name="DesktopToolBar" DockPanel.Dock="Top" Background="{StaticResource ShellSurfaceBrush}" BorderBrush="{StaticResource ShellBorderBrush}" BorderThickness="0,0,0,1" Padding="12,8,12,10">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                <StackPanel Orientation="Horizontal">
                    <Border Style="{StaticResource CommandSurfaceCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Project" Style="{StaticResource CommandSurfaceHeaderStyle}"/>
                            <TextBlock Text="Open files, switch layouts, and undo mistakes." Foreground="{StaticResource ShellMutedTextBrush}" TextWrapping="Wrap" Margin="0,4,0,8"/>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="220"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Name" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{StaticResource ShellMutedTextBrush}"/>
                                <TextBox x:Name="ProjectNameTextBox"
                                         Grid.Column="1"
                                         MinWidth="220"
                                         Text="{Binding DataContext.ProjectName, ElementName=RootWindow, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="Project name used for live title blocks and exports."
                                         AutomationProperties.AutomationId="ProjectNameTextBox"/>
                            </Grid>
                            <WrapPanel>
                                <Button Content="Undo" Click="Undo_Click" ToolTip="Undo (Ctrl+Z)"/>
                                <Button Content="Redo" Click="Redo_Click" ToolTip="Redo (Ctrl+Y)"/>
                                <Button x:Name="MobileViewButton" Content="Mobile View" Click="MobileViewButton_Click" ToolTip="Switch to Mobile (iPhone) View"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CommandSurfaceCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Add Parts" Style="{StaticResource CommandSurfaceHeaderStyle}"/>
                            <TextBlock Text="Drop common electrical parts into the drawing." Foreground="{StaticResource ShellMutedTextBrush}" TextWrapping="Wrap" Margin="0,4,0,8"/>
                            <WrapPanel>
                                <Button Content="Conduit" Click="AddConduit_Click" AutomationProperties.AutomationId="AddConduitButton"/>
                                <Button Content="Box" Click="AddBox_Click" AutomationProperties.AutomationId="AddBoxButton"/>
                                <Button Content="Panel" Click="AddPanel_Click" AutomationProperties.AutomationId="AddPanelButton"/>
                                <Button Content="Support" Click="AddSupport_Click" AutomationProperties.AutomationId="AddSupportButton"/>
                                <Button Content="Cable Tray" Click="AddCableTray_Click" AutomationProperties.AutomationId="AddCableTrayButton"/>
                                <Button Content="Hanger" Click="AddHanger_Click" AutomationProperties.AutomationId="AddHangerButton"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CommandSurfaceCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Layout &amp; Route" Style="{StaticResource CommandSurfaceHeaderStyle}"/>
                            <TextBlock Text="Sketch geometry, edit conduit paths, and generate routed runs." Foreground="{StaticResource ShellMutedTextBrush}" TextWrapping="Wrap" Margin="0,4,0,8"/>
                            <WrapPanel>
                                <Button x:Name="DrawConduitButton" Content="Draw Conduit" Click="DrawConduit_Click" ToolTip="Click to place conduit vertices. Shift constrains to 0°/45°/90°. Double-click to finish." AutomationProperties.AutomationId="DrawConduitButton"/>
                                <Button x:Name="EditConduitPathButton" Content="Edit Conduit Path" Click="ToggleEditConduitPath_Click" AutomationProperties.AutomationId="EditConduitPathButton"/>
                                <Button x:Name="SketchLineButton" Content="Sketch Line" Click="SketchLine_Click" ToolTip="Draw a straight or multi-segment sketch line." AutomationProperties.AutomationId="SketchLineButton"/>
                                <Button x:Name="SketchRectangleButton" Content="Sketch Rectangle" Click="SketchRectangle_Click" ToolTip="Draw a sketch rectangle for box/panel conversion." AutomationProperties.AutomationId="SketchRectangleButton"/>
                                <Button x:Name="ConvertSketchButton" Content="Convert Sketch" Click="ConvertSketch_Click" ToolTip="Convert selected sketch into components." AutomationProperties.AutomationId="ConvertSketchButton"/>
                                <Button x:Name="FreehandConduitButton" Content="Freehand Conduit" Click="FreehandConduit_Click" ToolTip="Freehand sketch conduit path." AutomationProperties.AutomationId="FreehandConduitButton"/>
                                <Button x:Name="AutoRouteButton" Content="Auto-Route" Click="AutoRoute_Click" ToolTip="Generate a conduit run from the selected path or a default route." AutomationProperties.AutomationId="AutoRouteButton"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CommandSurfaceCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Run Settings" Style="{StaticResource CommandSurfaceHeaderStyle}"/>
                            <TextBlock Text="Adjust drawing scale, trade size, and unit context before routing." Foreground="{StaticResource ShellMutedTextBrush}" TextWrapping="Wrap" Margin="0,4,0,8"/>
                            <WrapPanel>
                                <TextBlock Text="Detail" VerticalAlignment="Center" Margin="5,8,2,0"/>
                                <ComboBox x:Name="DetailLevelCombo" Width="75" SelectionChanged="DetailLevel_Changed" SelectedIndex="0" Margin="4">
                                    <ComboBoxItem Content="Coarse"/>
                                    <ComboBoxItem Content="Medium"/>
                                    <ComboBoxItem Content="Fine"/>
                                </ComboBox>
                                <TextBlock Text="Size" VerticalAlignment="Center" Margin="5,8,2,0"/>
                                <ComboBox x:Name="TradeSizeCombo" Width="60" SelectionChanged="TradeSize_Changed" SelectedIndex="0" Margin="4">
                                    <ComboBoxItem Content="1/2"/>
                                    <ComboBoxItem Content="3/4"/>
                                    <ComboBoxItem Content="1"/>
                                    <ComboBoxItem Content="1-1/4"/>
                                    <ComboBoxItem Content="1-1/2"/>
                                    <ComboBoxItem Content="2"/>
                                </ComboBox>
                                <TextBlock Text="Grid" VerticalAlignment="Center" Margin="5,8,2,0"/>
                                <TextBox Text="{Binding GridSize}" Width="50" Margin="4"/>
                                <TextBlock Text="Units" VerticalAlignment="Center" Margin="5,8,2,0"/>
                                <ComboBox x:Name="UnitSystemCombo" Width="80" SelectionChanged="UnitSystem_Changed" Margin="4">
                                    <ComboBoxItem Content="Imperial" IsSelected="True"/>
                                    <ComboBoxItem Content="Metric"/>
                                </ComboBox>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CommandSurfaceCardStyle}" Margin="0">
                        <StackPanel>
                            <TextBlock Text="Export" Style="{StaticResource CommandSurfaceHeaderStyle}"/>
                            <TextBlock Text="Send routed conduit data out once runs exist." Foreground="{StaticResource ShellMutedTextBrush}" TextWrapping="Wrap" Margin="0,4,0,8"/>
                            <WrapPanel>
                                <Button x:Name="ExportRunsCsvButton" Content="Export Runs CSV" Click="ExportRunSchedule_Click" IsEnabled="False"
                                        AutomationProperties.AutomationId="ExportRunsCsvButton"
                                        ToolTip="Disabled until at least one conduit run exists. Use Auto-Route or Freehand Conduit first."/>
                                <Button x:Name="ExportConduitJsonButton" Content="Export Conduit JSON" Click="ExportConduitJson_Click" IsEnabled="False"
                                        AutomationProperties.AutomationId="ExportConduitJsonButton"
                                        ToolTip="Disabled until at least one conduit run exists. Use Auto-Route or Freehand Conduit first."/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- OSNAP / Tracking status bar -->
        <ToolBar x:Name="OsnapToolBar" DockPanel.Dock="Top" Height="26">
            <ToggleButton x:Name="OsnapAllToggle" Content="OSNAP" ToolTip="F3 — Toggle all object snaps"
                          Click="OsnapAll_Click" Width="56" FontSize="10"/>
            <Separator/>
            <ToggleButton x:Name="SnapEndpointToggle" Content="END" ToolTip="Endpoint snap"
                          Click="SnapMode_Click" Tag="Endpoint" FontSize="10"/>
            <ToggleButton x:Name="SnapMidpointToggle" Content="MID" ToolTip="Midpoint snap"
                          Click="SnapMode_Click" Tag="Midpoint" FontSize="10"/>
            <ToggleButton x:Name="SnapCenterToggle" Content="CEN" ToolTip="Center snap"
                          Click="SnapMode_Click" Tag="Center" FontSize="10"/>
            <ToggleButton x:Name="SnapIntersectToggle" Content="INT" ToolTip="Intersection snap"
                          Click="SnapMode_Click" Tag="Intersection" FontSize="10"/>
            <ToggleButton x:Name="SnapPerpendicularToggle" Content="PER" ToolTip="Perpendicular snap"
                          Click="SnapMode_Click" Tag="Perpendicular" FontSize="10"/>
            <ToggleButton x:Name="SnapNearestToggle" Content="NEA" ToolTip="Nearest snap"
                          Click="SnapMode_Click" Tag="Nearest" FontSize="10"/>
            <ToggleButton x:Name="SnapQuadrantToggle" Content="QUA" ToolTip="Quadrant snap"
                          Click="SnapMode_Click" Tag="Quadrant" FontSize="10"/>
            <ToggleButton x:Name="SnapTangentToggle" Content="TAN" ToolTip="Tangent snap"
                          Click="SnapMode_Click" Tag="Tangent" FontSize="10"/>
            <Separator/>
            <ToggleButton x:Name="OrthoToggle" Content="ORTHO F8" ToolTip="F8 — Ortho mode (constrain to 0°/90°)"
                          Click="OrthoToggle_Click" FontSize="10"/>
            <ToggleButton x:Name="PolarToggle" Content="POLAR F10" ToolTip="F10 — Polar tracking"
                          Click="PolarToggle_Click" FontSize="10"/>
            <ComboBox x:Name="PolarAngleCombo" Width="55" ToolTip="Polar tracking increment angle"
                      SelectionChanged="PolarAngle_Changed" FontSize="10">
                <ComboBoxItem Content="5°"/>
                <ComboBoxItem Content="10°"/>
                <ComboBoxItem Content="15°"/>
                <ComboBoxItem Content="18°"/>
                <ComboBoxItem Content="22.5°"/>
                <ComboBoxItem Content="30°" IsSelected="True"/>
                <ComboBoxItem Content="45°"/>
                <ComboBoxItem Content="90°"/>
            </ComboBox>
        </ToolBar>

        <!-- Mobile top app bar -->
        <Border x:Name="MobileTopBar"
                DockPanel.Dock="Top"
                Background="{StaticResource MobileSurfaceBrush}"
                BorderBrush="{StaticResource MobileBorderBrush}"
                BorderThickness="0,0,0,1"
                Visibility="Collapsed">
            <Grid x:Name="MobileTopBarGrid" Margin="8,4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid x:Name="MobileTopBarHeaderGrid" Grid.Row="0" Height="52">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Grid.Column="0">
                        <Button x:Name="MobileUndoButton" Content="Undo" Click="Undo_Click" Style="{StaticResource MobileTopActionButtonStyle}"/>
                        <Button x:Name="MobileRedoButton" Content="Redo" Click="Redo_Click" Style="{StaticResource MobileTopActionButtonStyle}"/>
                    </StackPanel>
                    <TextBlock x:Name="MobileSectionTitleText"
                               Grid.Column="1"
                               Text="Canvas"
                               FontSize="17"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               Margin="0,-10,0,0"/>
                    <TextBlock x:Name="MobileTaskSummaryText"
                               Grid.Column="1"
                               Text="Import a reference or place the first part to start the layout."
                               FontSize="11"
                               Foreground="{StaticResource ShellMutedTextBrush}"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Margin="18,18,18,-2"/>
                    <StackPanel Orientation="Horizontal" Grid.Column="2" VerticalAlignment="Center">
                        <Button x:Name="MobileAddTopButton"
                                Content="Add"
                                Click="MobileAddTopButton_Click"
                                Style="{StaticResource MobileTopActionButtonStyle}">
                            <Button.ContextMenu>
                                <ContextMenu x:Name="MobileAddMenu"/>
                            </Button.ContextMenu>
                        </Button>
                        <Button x:Name="MobileMoreButton"
                                Content="More"
                                Click="MobileMoreButton_Click"
                                Style="{StaticResource MobileTopActionButtonStyle}">
                            <Button.ContextMenu>
                                <ContextMenu x:Name="MobileMoreMenu">
                                    <MenuItem x:Name="MobileThemeIosMenuItem" Header="Theme: iOS" IsCheckable="True" Click="MobileThemeIosMenuItem_Click"/>
                                    <MenuItem x:Name="MobileThemeAndroidMenuItem" Header="Theme: Android" IsCheckable="True" Click="MobileThemeAndroidMenuItem_Click"/>
                                </ContextMenu>
                            </Button.ContextMenu>
                        </Button>
                    </StackPanel>
                </Grid>
                <Border x:Name="MobileProjectNameBar"
                        Grid.Row="1"
                        Margin="10,0,10,4"
                        Padding="8,6"
                        Background="{StaticResource MobileSurfaceAltBrush}"
                        BorderBrush="{StaticResource MobileBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="MobileProjectNameLabelText"
                                   Text="Project"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource ShellMutedTextBrush}"
                                   FontSize="11"
                                   Margin="0,0,8,0"/>
                        <TextBox x:Name="MobileProjectNameTextBox"
                                 Grid.Column="1"
                                 MinWidth="160"
                                 Height="30"
                                 Padding="8,4"
                                 FontSize="13"
                                 Text="{Binding DataContext.ProjectName, ElementName=RootWindow, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="Project name used for live title blocks and exports."
                                 AutomationProperties.AutomationId="MobileProjectNameTextBox"/>
                    </Grid>
                </Border>
                <Border x:Name="MobileOnboardingActionBar"
                        Grid.Row="2"
                        Margin="10,2,10,6"
                        Padding="10,8"
                        Background="{StaticResource ShellCardBrush}"
                        BorderBrush="{StaticResource MobileBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock x:Name="MobileOnboardingProgressText"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource ShellMutedTextBrush}"/>
                        <TextBlock x:Name="MobileOnboardingActionTitleText"
                                   Margin="0,2,0,0"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource ShellPrimaryTextBrush}"
                                   TextWrapping="Wrap"/>
                        <WrapPanel x:Name="MobileOnboardingActionButtonsPanel" Margin="0,8,0,0">
                            <Button x:Name="MobileOnboardingPrimaryActionButton"
                                    MinWidth="96"
                                    Click="WorkspaceOnboardingAction_Click"
                                    Style="{StaticResource QuickActionButtonStyle}"/>
                            <Button x:Name="MobileOnboardingSecondaryActionButton"
                                    MinWidth="96"
                                    Click="WorkspaceOnboardingAction_Click"
                                    Style="{StaticResource QuickActionButtonStyle}"/>
                            <Button x:Name="MobileOnboardingDismissButton"
                                    Content="Later"
                                    Click="DismissWorkspaceOnboarding_Click"
                                    Foreground="{StaticResource MobileMutedTextBrush}"
                                    Style="{StaticResource MobileTopActionButtonStyle}"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Mobile bottom navigation -->
        <Border x:Name="MobileBottomNav"
                DockPanel.Dock="Bottom"
                Background="{StaticResource MobileSurfaceBrush}"
                BorderBrush="{StaticResource MobileBorderBrush}"
                BorderThickness="0,1,0,0"
                Visibility="Collapsed">
            <UniformGrid Columns="3" Rows="1">
                <Button x:Name="MobileCanvasButton" Content="Draw&#10;Plan" Click="MobileCanvasButton_Click" Style="{StaticResource MobileNavButtonStyle}"/>
                <Button x:Name="MobileLibraryButton" Content="Add&#10;Parts" Click="MobileLibraryButton_Click" Style="{StaticResource MobileNavButtonStyle}"/>
                <Button x:Name="MobilePropertiesButton" Content="Inspect&#10;Next" Click="MobilePropertiesButton_Click" Style="{StaticResource MobileNavButtonStyle}"/>
            </UniformGrid>
        </Border>

        <Border x:Name="DesktopWorkspaceOverview"
                DockPanel.Dock="Top"
                Margin="12,12,12,8"
                Padding="14"
                Background="{StaticResource ShellSurfaceBrush}"
                BorderBrush="{StaticResource ShellBorderBrush}"
                BorderThickness="1"
                CornerRadius="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,14,0">
                    <TextBlock Text="Guided Workspace"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource ShellPrimaryTextBrush}"
                               Margin="0"/>
                    <TextBlock Text="Key project context, current focus, and the next likely action stay visible here so first-time users do not need to decode every menu first."
                               TextWrapping="Wrap"
                               Foreground="{StaticResource ShellMutedTextBrush}"
                               Margin="0,6,0,0"/>
                    <Border x:Name="WorkspaceOnboardingCard"
                            Margin="0,12,0,0"
                            Padding="12"
                            Background="{StaticResource ShellCardBrush}"
                            BorderBrush="{StaticResource ShellBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock x:Name="WorkspaceOnboardingProgressTextBlock"
                                       Text="Step 1 of 3"
                                       FontSize="11"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource ShellMutedTextBrush}"
                                       Margin="0"/>
                            <TextBlock x:Name="WorkspaceOnboardingTitleTextBlock"
                                       Text="Bring in project context"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource ShellPrimaryTextBrush}"
                                       TextWrapping="Wrap"
                                       Margin="0,6,0,0"/>
                            <TextBlock x:Name="WorkspaceOnboardingSummaryTextBlock"
                                       Text="Import a reference drawing or open an existing project so the plan starts from real geometry instead of a blank canvas."
                                       TextWrapping="Wrap"
                                       Foreground="{StaticResource ShellMutedTextBrush}"
                                       Margin="0,6,0,0"/>
                            <TextBlock x:Name="WorkspaceOnboardingChecklistTextBlock"
                                       Text="Reference: next&#10;Layout: later&#10;Inspect: later"
                                       TextWrapping="Wrap"
                                       Foreground="{StaticResource ShellPrimaryTextBrush}"
                                       Margin="0,8,0,0"/>
                            <WrapPanel Margin="0,10,0,0">
                                <Button x:Name="WorkspaceOnboardingPrimaryActionButton"
                                        Content="Import Reference"
                                        Style="{StaticResource InspectorTaskActionButtonStyle}"
                                        Click="WorkspaceOnboardingAction_Click"/>
                                <Button x:Name="WorkspaceOnboardingSecondaryActionButton"
                                        Content="Open Project"
                                        Style="{StaticResource InspectorTaskActionButtonStyle}"
                                        Click="WorkspaceOnboardingAction_Click"/>
                                <Button x:Name="WorkspaceOnboardingDismissButton"
                                        Content="Hide Walkthrough"
                                        Style="{StaticResource InspectorTaskActionButtonStyle}"
                                        Click="DismissWorkspaceOnboarding_Click"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
                <Border Grid.Column="1"
                        Margin="0,0,10,0"
                        Padding="12"
                        Background="{StaticResource ShellCardBrush}"
                        BorderBrush="{StaticResource ShellBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                    <StackPanel>
                        <TextBlock Text="Workspace"
                                   FontSize="11"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource ShellMutedTextBrush}"
                                   Margin="0"/>
                        <TextBlock x:Name="WorkspaceOverviewTitleTextBlock"
                                   Text="No active drawing sheet"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource ShellPrimaryTextBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,6,0,0"/>
                        <TextBlock x:Name="WorkspaceOverviewDetailTextBlock"
                                   Text="Add a sheet or open a project to begin."
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource ShellMutedTextBrush}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="2"
                        Margin="0,0,10,0"
                        Padding="12"
                        Background="{StaticResource ShellCardBrush}"
                        BorderBrush="{StaticResource ShellBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                    <StackPanel>
                        <TextBlock Text="Focus"
                                   FontSize="11"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource ShellMutedTextBrush}"
                                   Margin="0"/>
                        <TextBlock x:Name="WorkspaceFocusTextBlock"
                                   Text="Nothing is selected yet."
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource ShellPrimaryTextBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="3"
                        Padding="12"
                        Background="{StaticResource ShellCardBrush}"
                        BorderBrush="{StaticResource ShellBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                    <StackPanel>
                        <TextBlock Text="Next Best Step"
                                   FontSize="11"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource ShellMutedTextBrush}"
                                   Margin="0"/>
                        <TextBlock x:Name="WorkspaceNextStepTextBlock"
                                   Text="Import a reference drawing or add the first component."
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource ShellPrimaryTextBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,6,0,0"/>
                        <TextBlock Text="Review Snapshot"
                                   FontSize="11"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource ShellMutedTextBrush}"
                                   Margin="0,10,0,0"/>
                        <TextBlock x:Name="WorkspaceReviewTextBlock"
                                   Text="No review issues yet."
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource ShellMutedTextBrush}"
                                   Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
        
        <!-- Main Content -->
        <Grid x:Name="MainContentGrid">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="LibraryColumn" Width="200"/>
                <ColumnDefinition x:Name="ViewportColumn" Width="*"/>
                <ColumnDefinition x:Name="PropertiesColumn" Width="300"/>
            </Grid.ColumnDefinitions>
            
            <!-- Library Browser + Layers -->
            <Border x:Name="LibraryPanelContainer" Grid.Column="0" BorderBrush="Gray" BorderThickness="0,0,1,0">
                <DockPanel>
                    <Border DockPanel.Dock="Top"
                            Margin="8,8,8,4"
                            Padding="10"
                            Background="{StaticResource ShellSurfaceBrush}"
                            BorderBrush="{StaticResource ShellBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                        <StackPanel>
                            <TextBlock Text="Start Here"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource ShellPrimaryTextBrush}"
                                       Margin="0"/>
                            <TextBlock x:Name="WorkspaceGuidanceTextBlock"
                                       Text="Start with a reference drawing, then place a few parts or sketch a conduit run."
                                       TextWrapping="Wrap"
                                       Foreground="{StaticResource ShellMutedTextBrush}"
                                       Margin="0,6,0,0"/>
                            <UniformGrid Columns="2" Margin="0,8,0,0">
                                <Button Style="{StaticResource QuickActionButtonStyle}" Content="Import Drawing" Click="ImportPdf_Click"/>
                                <Button Style="{StaticResource QuickActionButtonStyle}" Content="Add Conduit" Click="AddConduit_Click"/>
                                <Button Style="{StaticResource QuickActionButtonStyle}" Content="Draw Route" Click="DrawConduit_Click"/>
                                <Button Style="{StaticResource QuickActionButtonStyle}" Content="Add Review Note" Click="AddCallout_Click"/>
                            </UniformGrid>
                            <TextBlock x:Name="WorkspaceHintTextBlock"
                                       Text="Recommended path: import a sheet, add or route components, then review issues in the Markups tab."
                                       TextWrapping="Wrap"
                                       Foreground="{StaticResource ShellMutedTextBrush}"
                                       Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>
                    <TextBlock DockPanel.Dock="Top" Text="Project &amp; Sheets" 
                             FontWeight="Bold" FontSize="14" 
                             Padding="10" Background="LightGray"/>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="5">
                        <Button x:Name="AddSheetButton" Content="Add Sheet" Click="AddSheet_Click" Padding="5,2" Margin="2"/>
                        <Button x:Name="RenameSheetButton" Content="Rename" Click="RenameSheet_Click" Padding="5,2" Margin="2"/>
                        <Button x:Name="DeleteSheetButton" Content="Delete" Click="DeleteSheet_Click" Padding="5,2" Margin="2"/>
                    </StackPanel>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="5,0,5,5">
                        <Button x:Name="MoveSheetUpButton" Content="Up" Click="MoveSheetUp_Click" Padding="5,2" Margin="2"/>
                        <Button x:Name="MoveSheetDownButton" Content="Down" Click="MoveSheetDown_Click" Padding="5,2" Margin="2"/>
                        <TextBlock x:Name="ActiveSheetSummaryTextBlock" VerticalAlignment="Center" Margin="8,0,0,0" Text="1 sheet"/>
                    </StackPanel>
                    <Border DockPanel.Dock="Top"
                            Margin="5,0,5,5"
                            Padding="8"
                            Background="{StaticResource ShellSurfaceBrush}"
                            BorderBrush="{StaticResource ShellBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6">
                        <StackPanel>
                            <TextBlock Text="Sheet Details"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource ShellPrimaryTextBrush}"/>
                            <TextBlock x:Name="SheetRevisionSummaryTextBlock"
                                       Margin="0,4,0,0"
                                       Text="Select a sheet to manage revisions and approval state."
                                       TextWrapping="Wrap"
                                       Foreground="{StaticResource ShellMutedTextBrush}"/>
                            <TextBlock Text="Status"
                                       Margin="0,8,0,0"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource ShellPrimaryTextBrush}"/>
                            <ComboBox x:Name="SheetStatusComboBox"
                                      Margin="0,4,0,6"
                                      SelectionChanged="SheetStatusComboBox_SelectionChanged">
                                <ComboBoxItem Tag="Draft" Content="Draft"/>
                                <ComboBoxItem Tag="InReview" Content="In Review"/>
                                <ComboBoxItem Tag="Approved" Content="Approved"/>
                                <ComboBoxItem Tag="Archived" Content="Archived"/>
                            </ComboBox>
                            <WrapPanel Margin="0,0,0,6">
                                <Button x:Name="AddSheetRevisionButton"
                                        Content="Add Revision"
                                        Click="AddSheetRevision_Click"
                                        Margin="0,0,6,0"/>
                                <Button x:Name="RemoveSheetRevisionButton"
                                        Content="Remove Revision"
                                        Click="RemoveSheetRevision_Click"/>
                            </WrapPanel>
                            <TextBlock Text="Revision History"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource ShellPrimaryTextBrush}"/>
                            <ListBox x:Name="SheetRevisionListBox"
                                     Height="118"
                                     Margin="0,4,0,0"
                                     DisplayMemberPath="DisplayText"
                                     SelectionChanged="SheetRevisionListBox_SelectionChanged"/>
                        </StackPanel>
                    </Border>
                          <TreeView x:Name="ProjectBrowserTreeView"
                              DockPanel.Dock="Top"
                              Height="170"
                              Margin="5,0,5,5"
                              ItemsSource="{Binding ProjectBrowserItems}"
                              ItemContainerStyle="{StaticResource ProjectBrowserTreeItemStyle}"
                              SelectedItemChanged="ProjectBrowserTreeView_SelectedItemChanged"/>

                    <TextBlock DockPanel.Dock="Top" Text="Parts Catalog" 
                             FontWeight="Bold" FontSize="14" 
                             Padding="10" Background="LightGray"/>
                    <ListBox x:Name="LibraryListBox" DockPanel.Dock="Top" Height="200"
                           ItemsSource="{Binding LibraryComponents}"
                           DisplayMemberPath="Name"
                           SelectionChanged="LibraryListBox_SelectionChanged"
                           MouseDoubleClick="LibraryItem_DoubleClick"/>
                    
                    <!-- Layers Panel -->
                    <TextBlock DockPanel.Dock="Top" Text="Visibility &amp; Layers" 
                             FontWeight="Bold" FontSize="14" 
                             Padding="10" Background="LightGray"/>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="5">
                        <Button Content="Add" Click="AddLayer_Click" Padding="5,2" Margin="2"/>
                        <Button Content="Remove" Click="RemoveLayer_Click" Padding="5,2" Margin="2"/>
                        <Button Content="Export" Click="ExportLayers_Click" Padding="5,2" Margin="2" ToolTip="Export layer list to XML"/>
                    </StackPanel>
                    <DataGrid x:Name="LayerDataGrid"
                              DockPanel.Dock="Top"
                              ItemsSource="{Binding LayerManager.Rows}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              SelectionMode="Single"
                              RowHeight="22"
                              FontSize="11"
                              Height="160"
                              SelectionChanged="LayerDataGrid_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Header="V" Binding="{Binding IsVisible, UpdateSourceTrigger=PropertyChanged}" Width="24"/>
                            <DataGridCheckBoxColumn Header="L" Binding="{Binding IsLocked, UpdateSourceTrigger=PropertyChanged}" Width="24"/>
                            <DataGridCheckBoxColumn Header="F" Binding="{Binding IsFrozen, UpdateSourceTrigger=PropertyChanged}" Width="24"/>
                            <DataGridCheckBoxColumn Header="P" Binding="{Binding IsPlotted, UpdateSourceTrigger=PropertyChanged}" Width="24"/>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Color" Binding="{Binding Color}" Width="50" IsReadOnly="True"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <!-- Legacy list (hidden) kept for code-behind layer-assignment combobox population -->
                    <ListBox x:Name="LayerListBox"
                           Visibility="Collapsed"
                           ItemsSource="{Binding Layers}"
                           DisplayMemberPath="Name"
                           SelectionChanged="LayerListBox_SelectionChanged"/>
                </DockPanel>
            </Border>

            <GridSplitter x:Name="LibraryGridSplitter"
                          Grid.Column="0"
                          Width="6"
                          Panel.ZIndex="10"
                          Cursor="SizeWE"
                          HorizontalAlignment="Right"
                          VerticalAlignment="Stretch"
                          ResizeDirection="Columns"
                          ResizeBehavior="PreviousAndNext"
                          ShowsPreview="True"
                          Background="#22000000"
                          DragCompleted="LibraryGridSplitter_DragCompleted"/>
            
            <!-- 2D/3D Viewport Tab -->
            <Border x:Name="ViewportPanelContainer" Grid.Column="1" BorderBrush="Gray" BorderThickness="0,0,1,0">
                <DockPanel>
                    <TabControl x:Name="ViewTabs" DockPanel.Dock="Top">
                        <!-- 3D Viewport Tab -->
                        <TabItem Header="3D Viewport">
                            <Grid>
                                <!-- Section cut slider -->
                                <StackPanel VerticalAlignment="Bottom" Orientation="Horizontal" 
                                           Background="#F0F0F0" Margin="0">
                                    <TextBlock Text="Section Cut:" VerticalAlignment="Center" Margin="6,3"/>
                                    <CheckBox x:Name="SectionCutEnabled" Content="Enable" 
                                             VerticalAlignment="Center" Margin="4,3"
                                             Checked="SectionCut_Changed" Unchecked="SectionCut_Changed"/>
                                    <Slider x:Name="SectionCutSlider" Width="250" 
                                           Minimum="-50" Maximum="50" Value="0" 
                                           VerticalAlignment="Center" Margin="4,3"
                                           IsEnabled="{Binding IsChecked, ElementName=SectionCutEnabled}"
                                           ValueChanged="SectionCutSlider_Changed"
                                           TickFrequency="5" IsSnapToTickEnabled="False"/>
                                    <TextBlock x:Name="SectionCutValueText" Text="Y=0.00" 
                                             VerticalAlignment="Center" Margin="4,3" Width="55"/>
                                </StackPanel>
                                <h:HelixViewport3D x:Name="Viewport" 
                                                 Background="White"
                                                 ShowCoordinateSystem="True"
                                                 ShowViewCube="True"
                                                 MouseLeftButtonDown="Viewport_MouseLeftButtonDown">
                                    
                                    <!-- Lighting -->
                                    <h:DefaultLights/>
                                    
                                    <!-- Grid -->
                                    <h:GridLinesVisual3D x:Name="GridLines" 
                                                        Visible="{Binding ShowGrid}"
                                                        Width="100"
                                                        Length="100"
                                                        MinorDistance="1"
                                                        MajorDistance="10"
                                                        Thickness="0.01"
                                                        Fill="LightGray"/>
                                </h:HelixViewport3D>
                                <Border x:Name="ViewportGuidanceCard"
                                        Grid.ZIndex="20"
                                        Style="{StaticResource CanvasGuidanceCardStyle}"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Visibility="Collapsed">
                                    <StackPanel>
                                        <TextBlock x:Name="ViewportGuidanceTitleTextBlock"
                                                   Text="3D workspace is empty"
                                                   Style="{StaticResource CanvasGuidanceTitleStyle}"/>
                                        <TextBlock x:Name="ViewportGuidanceSummaryTextBlock"
                                                   Text="Place the first part to begin shaping the model in 3D."
                                                   Style="{StaticResource CanvasGuidanceBodyStyle}"/>
                                        <TextBlock x:Name="ViewportGuidanceHintTextBlock"
                                                   Text="You can start in 2D to trace a reference drawing, then return here to verify elevation and fit."
                                                   Style="{StaticResource CanvasGuidanceBodyStyle}"/>
                                        <WrapPanel Margin="0,8,0,0">
                                            <Button Content="Add Equipment"
                                                    Style="{StaticResource CanvasGuidanceActionButtonStyle}"
                                                    Click="AddBox_Click"/>
                                            <Button Content="Open 2D Plan"
                                                    Style="{StaticResource CanvasGuidanceActionButtonStyle}"
                                                    Click="Show2DView_Click"/>
                                        </WrapPanel>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </TabItem>
                        
                        <!-- 2D Plan View Tab -->
                        <TabItem Header="2D Plan View">
                            <Grid>
                                <!-- PDF underlay controls -->
                                <DockPanel>
                                    <StackPanel x:Name="PdfControlsPanel" DockPanel.Dock="Top" Orientation="Horizontal" 
                                              Background="#F0F0F0" Margin="0">
                                        <TextBlock Text="PDF:" VerticalAlignment="Center" Margin="5"/>
                                        <Button Content="Import PDF" Click="ImportPdf_Click" Padding="5,2" Margin="2"/>
                                        <TextBlock Text="Opacity:" VerticalAlignment="Center" Margin="5,0,0,0"/>
                                        <Slider x:Name="PdfOpacitySlider" Width="100" Minimum="0" Maximum="1" 
                                              Value="0.5" VerticalAlignment="Center" 
                                              ValueChanged="PdfOpacity_Changed"/>
                                        <CheckBox x:Name="PdfLockCheck" Content="Lock" 
                                                VerticalAlignment="Center" Margin="5" IsChecked="True"
                                                Checked="PdfLock_Changed" Unchecked="PdfLock_Changed"/>
                                        <Button Content="Calibrate Scale" Click="CalibrateScale_Click" Padding="5,2" Margin="2"/>
                                        <Separator Margin="5,0"/>
                                        <TextBlock Text="Page:" VerticalAlignment="Center" Margin="5,0,2,0"/>
                                        <Button x:Name="PdfPrevPageBtn" Content="◀" Click="PdfPrevPage_Click" Padding="4,2" Margin="1" ToolTip="Previous page"/>
                                        <TextBlock x:Name="PdfPageIndicator" Text="1 / 1" VerticalAlignment="Center" Margin="4,0"/>
                                        <Button x:Name="PdfNextPageBtn" Content="▶" Click="PdfNextPage_Click" Padding="4,2" Margin="1" ToolTip="Next page"/>
                                    </StackPanel>

                                    <!-- 2D drawing primitives toolbar -->
                                    <ToolBar x:Name="Drawing2DToolBar" DockPanel.Dock="Top" Height="26">
                                        <RadioButton GroupName="DrawTool2D" x:Name="Draw2DSelectRadio" Content="Select" IsChecked="True"
                                                     VerticalAlignment="Center" Margin="3,0" ToolTip="Select / Move (Esc)"
                                                     Checked="DrawTool2D_Changed" Tag="None" FontSize="10"/>
                                        <Separator/>
                                        <RadioButton GroupName="DrawTool2D" x:Name="Draw2DLineRadio" Content="Line"
                                                     VerticalAlignment="Center" Margin="3,0" ToolTip="Sketch Line"
                                                     Checked="DrawTool2D_Changed" Tag="Line" FontSize="10"/>
                                        <RadioButton GroupName="DrawTool2D" x:Name="Draw2DArcRadio" Content="Arc"
                                                     VerticalAlignment="Center" Margin="3,0" ToolTip="Arc annotation"
                                                     Checked="DrawTool2D_Changed" Tag="Arc" FontSize="10"/>
                                        <RadioButton GroupName="DrawTool2D" x:Name="Draw2DCircleRadio" Content="Circle"
                                                     VerticalAlignment="Center" Margin="3,0" ToolTip="Circle annotation"
                                                     Checked="DrawTool2D_Changed" Tag="Circle" FontSize="10"/>
                                        <RadioButton GroupName="DrawTool2D" x:Name="Draw2DPolylineRadio" Content="Polyline"
                                                     VerticalAlignment="Center" Margin="3,0" ToolTip="Polyline annotation"
                                                     Checked="DrawTool2D_Changed" Tag="Polyline" FontSize="10"/>
                                        <RadioButton GroupName="DrawTool2D" x:Name="Draw2DRectRadio" Content="Rect"
                                                     VerticalAlignment="Center" Margin="3,0" ToolTip="Rectangle annotation"
                                                     Checked="DrawTool2D_Changed" Tag="Rectangle" FontSize="10"/>
                                        <RadioButton GroupName="DrawTool2D" x:Name="Draw2DHatchRadio" Content="Hatch"
                                                     VerticalAlignment="Center" Margin="3,0" ToolTip="Hatch fill annotation"
                                                     Checked="DrawTool2D_Changed" Tag="Hatch" FontSize="10"/>
                                        <Separator/>
                                        <RadioButton GroupName="DrawTool2D" x:Name="Draw2DCalloutRadio" Content="Callout"
                                                     VerticalAlignment="Center" Margin="3,0" ToolTip="Callout annotation"
                                                     Checked="DrawTool2D_Changed" Tag="Callout" FontSize="10"/>
                                        <RadioButton GroupName="DrawTool2D" x:Name="Draw2DRevCloudRadio" Content="Rev Cloud"
                                                     VerticalAlignment="Center" Margin="3,0" ToolTip="Revision cloud"
                                                     Checked="DrawTool2D_Changed" Tag="RevisionCloud" FontSize="10"/>
                                        <Separator/>
                                        <RadioButton GroupName="DrawTool2D" x:Name="Draw2DDimensionRadio" Content="Dimension"
                                                     VerticalAlignment="Center" Margin="3,0" ToolTip="Place dimension annotation"
                                                     Checked="DrawTool2D_Changed" Tag="Dimension" FontSize="10"/>
                                    </ToolBar>
                                    
                                    <!-- 2D Canvas with pan/zoom -->
                                    <Grid>
                                        <!-- GPU-accelerated background layer (grid, markup) -->
                                        <rendering:SkiaCanvasHost x:Name="SkiaBackground"
                                            IsHitTestVisible="False"/>
                                        <ScrollViewer x:Name="PlanScrollViewer" 
                                                    AutomationProperties.AutomationId="PlanScrollViewer"
                                                    HorizontalScrollBarVisibility="Auto"
                                                    VerticalScrollBarVisibility="Auto"
                                                    PanningMode="Both"
                                                    PanningDeceleration="0.001"
                                                    PanningRatio="1"
                                                    Background="Transparent">
                                            <Canvas x:Name="PlanCanvas" 
                                                  AutomationProperties.AutomationId="PlanCanvas"
                                                  Width="2000" Height="2000"
                                                  Background="Transparent"
                                                  IsManipulationEnabled="True"
                                                  ManipulationStarting="PlanCanvas_ManipulationStarting"
                                                  ManipulationDelta="PlanCanvas_ManipulationDelta"
                                                  MouseLeftButtonDown="PlanCanvas_MouseLeftButtonDown"
                                                  MouseMove="PlanCanvas_MouseMove"
                                                  MouseLeftButtonUp="PlanCanvas_MouseLeftButtonUp"
                                                  MouseWheel="PlanCanvas_MouseWheel">
                                                <Canvas.LayoutTransform>
                                                    <ScaleTransform x:Name="PlanCanvasScale" ScaleX="1" ScaleY="1"/>
                                                </Canvas.LayoutTransform>
                                            </Canvas>
                                        </ScrollViewer>
                                        <Border x:Name="PlanCanvasGuidanceCard"
                                                Grid.ZIndex="20"
                                                Style="{StaticResource CanvasGuidanceCardStyle}"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Visibility="Collapsed">
                                            <StackPanel>
                                                <TextBlock x:Name="PlanCanvasGuidanceTitleTextBlock"
                                                           Text="Start the 2D plan"
                                                           Style="{StaticResource CanvasGuidanceTitleStyle}"/>
                                                <TextBlock x:Name="PlanCanvasGuidanceSummaryTextBlock"
                                                           Text="Import a drawing underlay or place the first conduit run to begin layout work."
                                                           Style="{StaticResource CanvasGuidanceBodyStyle}"/>
                                                <TextBlock x:Name="PlanCanvasGuidanceHintTextBlock"
                                                           Text="2D is the fastest place to trace, place, and review before checking the model in 3D."
                                                           Style="{StaticResource CanvasGuidanceBodyStyle}"/>
                                                <WrapPanel Margin="0,8,0,0">
                                                    <Button x:Name="PlanCanvasGuidancePrimaryActionButton"
                                                        Content="Import Reference"
                                                            Style="{StaticResource CanvasGuidanceActionButtonStyle}"
                                                        Click="PlanCanvasGuidanceAction_Click"/>
                                                    <Button x:Name="PlanCanvasGuidanceSecondaryActionButton"
                                                        Content="Add Conduit"
                                                            Style="{StaticResource CanvasGuidanceActionButtonStyle}"
                                                        Click="PlanCanvasGuidanceAction_Click"/>
                                                </WrapPanel>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </DockPanel>
                            </Grid>
                        </TabItem>
                    </TabControl>
                </DockPanel>
            </Border>
            
            <!-- Properties Panel -->
            <Border x:Name="PropertiesPanelContainer" Grid.Column="2" BorderBrush="Gray" BorderThickness="0">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Style="{StaticResource InspectorHeaderCardStyle}">
                        <StackPanel>
                            <TextBlock x:Name="InspectorTitleTextBlock"
                                       Text="Contextual Inspector"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource ShellPrimaryTextBrush}"
                                       Margin="0"/>
                            <TextBlock x:Name="InspectorSummaryTextBlock"
                                       Text="Select a component or markup to focus the inspector."
                                       TextWrapping="Wrap"
                                       Foreground="{StaticResource ShellPrimaryTextBrush}"
                                       Margin="0,4,0,0"/>
                            <TextBlock x:Name="InspectorHintTextBlock"
                                       Text="Component details stay on the left tab. Review threads, status, and replies stay on the right tab."
                                       TextWrapping="Wrap"
                                       Foreground="{StaticResource ShellMutedTextBrush}"
                                       Margin="0,4,0,0"/>
                            <WrapPanel Margin="0,8,0,0">
                                <Button x:Name="InspectorComponentModeButton"
                                        Content="Component Details"
                                        Style="{StaticResource InspectorModeButtonStyle}"
                                        Click="ShowInspectorComponentMode_Click"/>
                                <Button x:Name="InspectorMarkupModeButton"
                                        Content="Review &amp; Markups"
                                        Style="{StaticResource InspectorModeButtonStyle}"
                                        Click="ShowInspectorMarkupMode_Click"/>
                            </WrapPanel>
                                <Border x:Name="InspectorTaskPanel"
                                    Margin="0,10,0,0"
                                    Style="{StaticResource InspectorTaskCardStyle}">
                                <StackPanel>
                                    <TextBlock x:Name="InspectorTaskTitleTextBlock"
                                           Text="Start Here"
                                           FontSize="12"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource ShellMutedTextBrush}"
                                           Margin="0"/>
                                    <TextBlock x:Name="InspectorTaskSummaryTextBlock"
                                           Text="Bring in a reference, place the first conduit run, or jump into markup review."
                                           TextWrapping="Wrap"
                                           Foreground="{StaticResource ShellPrimaryTextBrush}"
                                           Margin="0,6,0,0"/>
                                    <WrapPanel Margin="0,8,0,0">
                                    <Button x:Name="InspectorPrimaryActionButton"
                                        Content="Import Reference"
                                        Style="{StaticResource InspectorTaskActionButtonStyle}"
                                        Click="InspectorActionButton_Click"/>
                                    <Button x:Name="InspectorSecondaryActionButton"
                                        Content="Add Conduit"
                                        Style="{StaticResource InspectorTaskActionButtonStyle}"
                                        Click="InspectorActionButton_Click"/>
                                    <Button x:Name="InspectorTertiaryActionButton"
                                        Content="Review Markups"
                                        Style="{StaticResource InspectorTaskActionButtonStyle}"
                                        Click="InspectorActionButton_Click"/>
                                    </WrapPanel>
                                </StackPanel>
                                </Border>
                        </StackPanel>
                    </Border>

                    <TabControl x:Name="RightPanelTabs" SelectionChanged="RightPanelTabs_SelectionChanged">

                    <!-- Properties tab (existing content) -->
                    <TabItem x:Name="PropertiesInspectorTab" Header="Component Details">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="Component Details" 
                                     FontWeight="Bold" FontSize="14" 
                                     Padding="10" Background="LightGray"/>
                    
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel x:Name="PropertiesPanel" Margin="10">
                            <TextBlock Text="Select a component to view properties" 
                                     FontStyle="Italic" Foreground="Gray"
                                     Visibility="{Binding SelectedComponent, 
                                     Converter={StaticResource NullToVisibilityConverter}}"/>
                            
                            <StackPanel x:Name="ComponentProperties" 
                                      Visibility="{Binding SelectedComponent, 
                                      Converter={StaticResource NotNullToVisibilityConverter}}">
                                  <TextBlock x:Name="MultiSelectionSummaryTextBlock"
                                         Visibility="Collapsed"
                                         Text=""
                                         TextWrapping="Wrap"
                                         Foreground="Gray"
                                         FontStyle="Italic"
                                         Margin="0,0,0,8"/>
                                
                                <!-- Basic Properties -->
                                <TextBlock Text="Basic Properties" FontWeight="Bold"/>
                                <TextBlock Text="Name:"/>
                                <TextBox x:Name="NameTextBox"/>
                                
                                <TextBlock Text="Type:"/>
                                <TextBox x:Name="TypeTextBox" IsReadOnly="True"/>
                                
                                <TextBlock Text="Layer:"/>
                                <ComboBox x:Name="LayerComboBox" 
                                        ItemsSource="{Binding Layers}" 
                                        DisplayMemberPath="Name" Margin="5"/>
                                
                                <!-- Transform Properties -->
                                <TextBlock Text="Transform" FontWeight="Bold" Margin="0,10,0,0"/>
                                
                                <TextBlock Text="Position X (2D left/right):"/>
                                <TextBox x:Name="PositionXTextBox"/>
                                
                                <TextBlock Text="Position Y (elevation):"/>
                                <TextBox x:Name="PositionYTextBox"/>
                                
                                <TextBlock Text="Position Z (2D up/down):"/>
                                <TextBox x:Name="PositionZTextBox"/>
                                
                                <TextBlock Text="Rotation X:"/>
                                <TextBox x:Name="RotationXTextBox"/>
                                
                                <TextBlock Text="Rotation Y:"/>
                                <TextBox x:Name="RotationYTextBox"/>
                                
                                <TextBlock Text="Rotation Z:"/>
                                <TextBox x:Name="RotationZTextBox"/>
                                
                                <!-- Parameters -->
                                <TextBlock Text="Parameters" FontWeight="Bold" Margin="0,10,0,0"/>
                                
                                <TextBlock Text="Width:"/>
                                <TextBox x:Name="WidthTextBox"/>
                                
                                <TextBlock Text="Height:"/>
                                <TextBox x:Name="HeightTextBox"/>
                                
                                <TextBlock Text="Depth:"/>
                                <TextBox x:Name="DepthTextBox"/>

                                <TextBlock Text="Selected Dimensions (Unique)" FontWeight="Bold" Margin="0,10,0,0"/>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Display:" VerticalAlignment="Center"/>
                                    <ComboBox x:Name="DimensionDisplayFormatCombo" Width="120" Margin="5,0,0,0"
                                              SelectionChanged="DimensionDisplayFormat_Changed">
                                        <ComboBoxItem Content="Feet-Inches" IsSelected="True"/>
                                        <ComboBoxItem Content="Decimal Feet"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Increment:" VerticalAlignment="Center"/>
                                    <ComboBox x:Name="DimensionIncrementCombo" Width="120" Margin="5,0,0,0"
                                              SelectionChanged="DimensionIncrement_Changed">
                                        <ComboBoxItem Tag="64" Content="1/64&quot;"/>
                                        <ComboBoxItem Tag="32" Content="1/32&quot;"/>
                                        <ComboBoxItem Tag="16" Content="1/16&quot;" IsSelected="True"/>
                                        <ComboBoxItem Tag="8" Content="1/8&quot;"/>
                                        <ComboBoxItem Tag="4" Content="1/4&quot;"/>
                                        <ComboBoxItem Tag="2" Content="1/2&quot;"/>
                                        <ComboBoxItem Tag="1" Content="1&quot;"/>
                                    </ComboBox>
                                </StackPanel>
                                <ListBox x:Name="SelectedDimensionsListBox" Height="100" Margin="0,2,0,6" IsHitTestVisible="False"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                    <Button x:Name="CustomDimensionModeButton"
                                            Content="Add Custom Dimension"
                                            Click="AddCustomDimension_Click"
                                            Margin="0,0,6,0"/>
                                    <Button x:Name="ClearCustomDimensionsButton"
                                            Content="Clear Custom Dims"
                                            Click="ClearCustomDimensions_Click"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                    <TextBlock Text="Snap:" VerticalAlignment="Center"/>
                                    <ComboBox x:Name="CustomDimensionSnapModeCombo"
                                              Width="140"
                                              Margin="5,0,0,0"
                                              SelectionChanged="CustomDimensionSnapMode_Changed">
                                        <ComboBoxItem Tag="Auto" Content="Auto" IsSelected="True"/>
                                        <ComboBoxItem Tag="Edge" Content="Edge"/>
                                        <ComboBoxItem Tag="Point" Content="Point"/>
                                        <ComboBoxItem Tag="Face" Content="Face"/>
                                        <ComboBoxItem Tag="Center" Content="Center"/>
                                        <ComboBoxItem Tag="Intersection" Content="Intersection"/>
                                    </ComboBox>
                                </StackPanel>
                                <TextBlock x:Name="CustomDimensionModeTextBlock"
                                           Text="Custom dimensions total: 0"
                                           Foreground="Gray"
                                           FontStyle="Italic"
                                           Margin="0,0,0,6"/>

                                <TextBlock Text="Project Parameter Bindings" FontWeight="Bold" Margin="0,10,0,0"/>
                                <TextBlock x:Name="ProjectParameterBindingSummaryTextBlock"
                                       Text="No project parameters are defined yet."
                                       TextWrapping="Wrap"
                                       Foreground="Gray"
                                       FontStyle="Italic"
                                       Margin="0,0,0,6"/>
                                <Button x:Name="ManageProjectParametersButton"
                                    Content="Manage Project Parameters..."
                                    Click="ManageProjectParameters_Click"
                                    Margin="0,0,0,8"/>

                                <Border x:Name="ProjectParameterEditorPanel"
                                    Visibility="Collapsed"
                                    Margin="0,0,0,8"
                                    Padding="8"
                                    Background="{StaticResource ShellSurfaceBrush}"
                                    BorderBrush="{StaticResource ShellBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6">
                                    <StackPanel>
                                    <TextBlock Text="Project Parameter Editor" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <TextBlock Text="Search:" Margin="0,0,0,0"/>
                                    <TextBox x:Name="ProjectParameterSearchTextBox"
                                         TextChanged="ProjectParameterSearchTextBox_TextChanged"
                                         Margin="0,0,0,6"/>
                                    <ListBox x:Name="ProjectParameterListBox"
                                         Height="110"
                                         DisplayMemberPath="DisplayName"
                                         SelectionChanged="ProjectParameterListBox_SelectionChanged"
                                         Margin="0,0,0,6"/>
                                    <TextBlock x:Name="ProjectParameterUsageTextBlock"
                                           Text="No project parameters exist yet. Create one to reuse the same dimensional value across multiple components."
                                           TextWrapping="Wrap"
                                           Foreground="Gray"
                                           FontStyle="Italic"
                                           Margin="0,0,0,6"/>
                                    <TextBlock Text="Name:" Margin="0,0,0,0"/>
                                    <TextBox x:Name="ProjectParameterNameEditorTextBox"
                                         TextChanged="ProjectParameterNameEditorTextBox_TextChanged"
                                         Margin="0,0,0,6"/>
                                     <TextBlock Text="Type:" Margin="0,0,0,0"/>
                                     <ComboBox x:Name="ProjectParameterValueKindComboBox"
                                             Margin="0,0,0,6"
                                             SelectionChanged="ProjectParameterValueKindComboBox_SelectionChanged">
                                        <ComboBoxItem Tag="Length" Content="Length"/>
                                        <ComboBoxItem Tag="Text" Content="Text"/>
                                     </ComboBox>
                                    <TextBlock Text="Value:" Margin="0,0,0,0"/>
                                    <TextBox x:Name="ProjectParameterValueEditorTextBox"
                                         TextChanged="ProjectParameterValueEditorTextBox_TextChanged"
                                         Margin="0,0,0,6"/>
                                        <TextBlock Text="Formula (optional):" Margin="0,0,0,0"/>
                                        <TextBox x:Name="ProjectParameterFormulaEditorTextBox"
                                                 Margin="0,0,0,4"
                                                 TextChanged="ProjectParameterFormulaEditorTextBox_TextChanged"/>
                                        <TextBlock Text="Length parameters support [Parameter Name] references with decimal arithmetic, for example [Base Width] * 2 + 0.5. Text parameters store direct values only."
                                                   TextWrapping="Wrap"
                                                   Foreground="Gray"
                                                   FontStyle="Italic"
                                                   Margin="0,0,0,6"/>
                                        <TextBlock x:Name="ProjectParameterPreviewTextBlock"
                                                   Visibility="Collapsed"
                                                   Foreground="SeaGreen"
                                                   Margin="0,0,0,4"
                                                   TextWrapping="Wrap"/>
                                        <TextBlock x:Name="ProjectParameterValidationTextBlock"
                                                   Visibility="Collapsed"
                                                   Foreground="Firebrick"
                                                   Margin="0,0,0,6"
                                                   TextWrapping="Wrap"/>
                                    <WrapPanel Margin="0,0,0,0">
                                        <Button x:Name="ProjectParameterNewButton"
                                            Content="New"
                                            Click="NewProjectParameter_Click"
                                            Margin="0,0,6,0"/>
                                        <Button x:Name="ProjectParameterSaveButton"
                                            Content="Add Parameter"
                                            Click="SaveProjectParameter_Click"
                                            Margin="0,0,6,0"/>
                                        <Button x:Name="ProjectParameterDeleteButton"
                                            Content="Delete"
                                            Click="DeleteProjectParameter_Click"
                                            IsEnabled="False"
                                            Margin="0,0,6,0"/>
                                        <Button x:Name="ProjectParameterCloseButton"
                                            Content="Close"
                                            Click="CloseProjectParameterEditor_Click"
                                            Margin="0"/>
                                    </WrapPanel>
                                    </StackPanel>
                                </Border>

                                <TextBlock Text="Width Parameter:"/>
                                <ComboBox x:Name="WidthParameterBindingComboBox"
                                      DisplayMemberPath="DisplayName"
                                      SelectedValuePath="ParameterId"/>

                                <TextBlock Text="Height Parameter:" Margin="0,6,0,0"/>
                                <ComboBox x:Name="HeightParameterBindingComboBox"
                                      DisplayMemberPath="DisplayName"
                                      SelectedValuePath="ParameterId"/>

                                <TextBlock Text="Depth Parameter:" Margin="0,6,0,0"/>
                                <ComboBox x:Name="DepthParameterBindingComboBox"
                                      DisplayMemberPath="DisplayName"
                                      SelectedValuePath="ParameterId"/>

                                <TextBlock Text="Elevation Parameter:" Margin="0,6,0,0"/>
                                <ComboBox x:Name="ElevationParameterBindingComboBox"
                                      DisplayMemberPath="DisplayName"
                                      SelectedValuePath="ParameterId"/>
                                
                                <TextBlock Text="Material:"/>
                                <TextBox x:Name="MaterialTextBox"/>
                                  <TextBlock Text="Material Parameter:" Margin="0,4,0,0"/>
                                  <ComboBox x:Name="MaterialParameterBindingComboBox"
                                      DisplayMemberPath="DisplayName"
                                      SelectedValuePath="ParameterId"/>
                                
                                <TextBlock Text="Elevation:"/>
                                <TextBox x:Name="ElevationTextBox"/>
                                
                                <TextBlock Text="Color:"/>
                                <TextBox x:Name="ColorTextBox"/>

                                <TextBlock Text="Manufacturer:"/>
                                <TextBox x:Name="ManufacturerTextBox"/>
                                  <TextBlock Text="Manufacturer Parameter:" Margin="0,4,0,0"/>
                                  <ComboBox x:Name="ManufacturerParameterBindingComboBox"
                                      DisplayMemberPath="DisplayName"
                                      SelectedValuePath="ParameterId"/>

                                <TextBlock Text="Part Number:"/>
                                <TextBox x:Name="PartNumberTextBox"/>
                                  <TextBlock Text="Part Number Parameter:" Margin="0,4,0,0"/>
                                  <ComboBox x:Name="PartNumberParameterBindingComboBox"
                                      DisplayMemberPath="DisplayName"
                                      SelectedValuePath="ParameterId"/>

                                <TextBlock Text="Reference URL:"/>
                                <TextBox x:Name="ReferenceUrlTextBox"/>
                                  <TextBlock Text="Reference URL Parameter:" Margin="0,4,0,0"/>
                                  <ComboBox x:Name="ReferenceUrlParameterBindingComboBox"
                                      DisplayMemberPath="DisplayName"
                                      SelectedValuePath="ParameterId"/>
                                <Button x:Name="OpenReferenceButton" Content="Open Reference" Click="OpenReference_Click" Margin="0,4,0,0"/>
                                <TextBlock x:Name="ReferenceRootStatusTextBlock" Foreground="Gray" FontStyle="Italic" Text="Reference root: (auto)"/>
                                <TextBlock Text="Curated References:"/>
                                <ComboBox x:Name="ReferenceCatalogComboBox" DisplayMemberPath="DisplayName" SelectedValuePath="RelativePath"/>
                                <WrapPanel Margin="0,4,0,0">
                                    <Button x:Name="AssignReferenceButton" Content="Use Selected Reference" Click="AssignSelectedReference_Click" Margin="0,0,6,0"/>
                                    <Button x:Name="SuggestedReferenceButton" Content="Use Suggested Reference" Click="ApplySuggestedReference_Click"/>
                                </WrapPanel>
                                
                                <!-- Conduit-specific Properties -->
                                <StackPanel x:Name="ConduitProperties" Visibility="Collapsed">
                                    <TextBlock Text="Conduit Settings" FontWeight="Bold" Margin="0,10,0,0"/>
                                    
                                    <TextBlock Text="Bend Points:"/>
                                    <TextBlock x:Name="BendPointsTextBlock" Text="0" Foreground="Gray" FontStyle="Italic" Margin="5,0,0,5"/>
                                    
                                    <Button x:Name="ClearBendPointsButton" Content="Clear All Bend Points" 
                                            Click="ClearBendPoints_Click" Margin="5"/>
                                </StackPanel>
                                
                                <!-- Actions -->
                                <Button x:Name="ApplyPropertiesButton" Content="Apply Changes" Click="ApplyProperties_Click" Margin="0,10,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                        </DockPanel>
                    </TabItem>

                    <!-- Markups tab -->
                    <TabItem x:Name="MarkupsInspectorTab" Header="Review &amp; Markups">
                        <DockPanel>
                            <!-- Filter bar -->
                            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="4,4,4,0" VerticalAlignment="Center">
                                <TextBlock Text="Scope:" VerticalAlignment="Center" FontSize="11"/>
                                <ComboBox x:Name="MarkupReviewScopeCombo" Width="110" FontSize="11" Margin="3,0,8,0"
                                          ItemsSource="{Binding MarkupTool.ReviewScopeOptions}"
                                          SelectedItem="{Binding MarkupTool.ReviewScope, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          SelectionChanged="MarkupReviewScope_Changed"/>
                                <TextBlock Text="Status:" VerticalAlignment="Center" FontSize="11"/>
                                <ComboBox x:Name="MarkupStatusFilterCombo" Width="92" FontSize="11" Margin="3,0,8,0"
                                          ItemsSource="{Binding MarkupTool.StatusFilterOptions}"
                                          SelectedItem="{Binding MarkupTool.StatusFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          SelectionChanged="MarkupStatusFilter_Changed">
                                </ComboBox>
                                <TextBlock Text="Type:" VerticalAlignment="Center" FontSize="11"/>
                                <ComboBox x:Name="MarkupTypeFilterCombo" Width="120" FontSize="11" Margin="3,0,8,0"
                                          ItemsSource="{Binding MarkupTool.TypeFilterOptions}"
                                          SelectedItem="{Binding MarkupTool.TypeFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          SelectionChanged="MarkupTypeFilter_Changed"/>
                                <TextBlock Text="Layer:" VerticalAlignment="Center" FontSize="11"/>
                                <ComboBox x:Name="MarkupLayerFilterCombo" Width="112" FontSize="11" Margin="3,0,8,0"
                                          ItemsSource="{Binding MarkupTool.LayerFilterOptions}"
                                          SelectedItem="{Binding MarkupTool.LayerFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          SelectionChanged="MarkupLayerFilter_Changed"/>
                                <TextBlock Text="Assignee:" VerticalAlignment="Center" FontSize="11"/>
                                <ComboBox x:Name="MarkupAssigneeFilterCombo" Width="118" FontSize="11" Margin="3,0,8,0"
                                          ItemsSource="{Binding MarkupTool.AssigneeFilterOptions}"
                                          SelectedItem="{Binding MarkupTool.AssigneeFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Text="Search:" VerticalAlignment="Center" FontSize="11"/>
                                <TextBox x:Name="MarkupSearchBox" Width="122" FontSize="11" Margin="3,0,8,0"
                                         ToolTip="Search labels, subjects, layers, assignees, authors, and reply text"
                                         TextChanged="MarkupSearch_Changed"/>
                            </StackPanel>
                            <!-- Counts -->
                            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="4,2">
                                <TextBlock FontSize="10" Foreground="Gray"
                                           Text="{Binding MarkupTool.TotalCount, StringFormat='Total: {0}'}"/>
                                <TextBlock FontSize="10" Foreground="OrangeRed" Margin="8,0,0,0"
                                           Text="{Binding MarkupTool.OpenCount, StringFormat='Open: {0}'}"/>
                                <TextBlock FontSize="10" Foreground="#9A6700" Margin="8,0,0,0"
                                           Text="{Binding MarkupTool.InProgressCount, StringFormat='In Progress: {0}'}"/>
                                <TextBlock FontSize="10" Foreground="#0A7D29" Margin="8,0,0,0"
                                           Text="{Binding MarkupTool.ApprovedCount, StringFormat='Resolved: {0}'}"/>
                                <TextBlock FontSize="10" Foreground="#6E7781" Margin="8,0,0,0"
                                           Text="{Binding MarkupTool.VoidCount, StringFormat='Void: {0}'}"/>
                                <TextBlock FontSize="10" Foreground="Gray" Margin="8,0,0,0"
                                           Text="{Binding MarkupTool.FilteredCount, StringFormat='Filtered: {0}'}"/>
                            </StackPanel>
                            <Border DockPanel.Dock="Top"
                                    Margin="4,0,4,6"
                                    Padding="8"
                                    Background="#FFF7F7F8"
                                    BorderBrush="#FFD0D7DE"
                                    BorderThickness="1">
                                <DockPanel>
                                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="Issue Buckets:" FontWeight="Bold" FontSize="11" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Text="Group By:" VerticalAlignment="Center" FontSize="11"/>
                                        <ComboBox x:Name="MarkupIssueGroupModeCombo"
                                                  Width="108"
                                                  FontSize="11"
                                                  Margin="3,0,8,0"
                                                  ItemsSource="{Binding MarkupTool.IssueGroupModeOptions}"
                                                  SelectedItem="{Binding MarkupTool.IssueGroupMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                        <Button Content="All Buckets"
                                                Padding="8,2"
                                                Margin="0,0,8,0"
                                            Command="{Binding MarkupTool.ClearIssueGroupCommand}"/>
                                        <TextBlock Text="{Binding MarkupTool.SelectedIssueGroupSummary}" FontSize="11" Foreground="Gray" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <ListView x:Name="MarkupIssueGroupListView"
                                              Margin="0,8,0,0"
                                              Height="108"
                                              ItemsSource="{Binding MarkupTool.IssueGroups}"
                                              SelectedItem="{Binding MarkupTool.SelectedIssueGroup, Mode=TwoWay}">
                                        <ListView.View>
                                            <GridView>
                                                <GridViewColumn Header="Bucket" DisplayMemberBinding="{Binding DisplayName}" Width="138"/>
                                                <GridViewColumn Header="Details" DisplayMemberBinding="{Binding SecondaryText}" Width="118"/>
                                                <GridViewColumn Header="Mix" DisplayMemberBinding="{Binding BreakdownText}" Width="218"/>
                                                <GridViewColumn Header="Count" DisplayMemberBinding="{Binding Count}" Width="48"/>
                                                <GridViewColumn Header="Open" DisplayMemberBinding="{Binding OpenCount}" Width="48"/>
                                            </GridView>
                                        </ListView.View>
                                    </ListView>
                                    <WrapPanel Margin="0,8,0,0">
                                        <Button Content="Assign Bucket"
                                                Click="AssignSelectedIssueGroup_Click"
                                                Padding="8,2"
                                                Margin="0,0,6,4"
                                                IsEnabled="{Binding MarkupTool.HasSelectedIssueGroup}"
                                                ToolTip="Assign every issue in the selected bucket"/>
                                        <Button Content="Approve Bucket"
                                            Click="ApproveSelectedIssueGroup_Click"
                                            Padding="8,2"
                                            Margin="0,0,6,4"
                                            IsEnabled="{Binding MarkupTool.HasSelectedIssueGroup}"
                                            ToolTip="Approve every eligible issue in the selected bucket"/>
                                        <Button Content="Reject Bucket"
                                            Click="RejectSelectedIssueGroup_Click"
                                            Padding="8,2"
                                            Margin="0,0,6,4"
                                            IsEnabled="{Binding MarkupTool.HasSelectedIssueGroup}"
                                            ToolTip="Reject every eligible issue in the selected bucket"/>
                                        <Button Content="Resolve Bucket"
                                                Click="ResolveSelectedIssueGroup_Click"
                                                Padding="8,2"
                                                Margin="0,0,6,4"
                                                IsEnabled="{Binding MarkupTool.HasSelectedIssueGroup}"
                                                ToolTip="Resolve every eligible issue in the selected bucket"/>
                                        <Button Content="Void Bucket"
                                                Click="VoidSelectedIssueGroup_Click"
                                                Padding="8,2"
                                                Margin="0,0,6,4"
                                                IsEnabled="{Binding MarkupTool.HasSelectedIssueGroup}"
                                                ToolTip="Void every eligible issue in the selected bucket"/>
                                    </WrapPanel>
                                    <TextBlock Margin="0,2,0,0"
                                               FontSize="10"
                                               Foreground="Gray"
                                               TextWrapping="Wrap"
                                               Text="{Binding MarkupTool.SelectedIssueGroupActionSummary}"/>
                                    <TextBlock Margin="0,2,0,0"
                                               FontSize="10"
                                               Foreground="Gray"
                                               TextWrapping="Wrap"
                                               Text="{Binding MarkupTool.SelectedIssueGroupBreakdown}"/>
                                </DockPanel>
                            </Border>
                            <!-- Actions -->
                            <WrapPanel DockPanel.Dock="Top" Margin="4,4,4,6">
                                <Button Content="Edit Geometry"
                                        Click="EditSelectedMarkupGeometry_Click"
                                        Padding="8,2"
                                        Margin="0,0,6,4"
                                        IsEnabled="{Binding MarkupTool.HasGeometryEditableSelection}"
                                        ToolTip="{Binding MarkupTool.SelectedMarkupGeometryEditSummary}"/>
                                <Button Content="Edit Text"
                                    Click="EditSelectedStructuredMarkup_Click"
                                    Padding="8,2"
                                    Margin="0,0,6,4"
                                    IsEnabled="{Binding MarkupTool.HasTextEditableSelection}"
                                    ToolTip="{Binding MarkupTool.SelectedMarkupTextEditSummary}"/>
                                <Button Content="Edit Appearance"
                                    Click="EditSelectedMarkupAppearance_Click"
                                    Padding="8,2"
                                    Margin="0,0,6,4"
                                    IsEnabled="{Binding MarkupTool.HasAppearanceEditableSelection}"
                                    ToolTip="{Binding MarkupTool.SelectedMarkupAppearanceEditSummary}"/>
                                <Button Content="Insert Vertex"
                                    Click="InsertSelectedMarkupVertex_Click"
                                    Padding="8,2"
                                    Margin="0,0,6,4"
                                    IsEnabled="{Binding MarkupTool.HasPathVertexInsertCandidate}"
                                    ToolTip="{Binding MarkupTool.SelectedMarkupPathInsertSummary}"/>
                                <Button Content="Delete Vertex"
                                        Click="DeleteSelectedMarkupVertex_Click"
                                        Padding="8,2"
                                        Margin="0,0,6,4"
                                        IsEnabled="{Binding MarkupTool.HasPathVertexDeleteCandidate}"
                                        ToolTip="{Binding MarkupTool.SelectedMarkupPathDeleteSummary}"/>
                                <Button Content="Add Reply"
                                        Click="AddMarkupReply_Click"
                                        Padding="8,2"
                                        Margin="0,0,6,4"
                                        IsEnabled="{Binding MarkupTool.HasSelectedMarkup}"
                                        ToolTip="Add a threaded review reply to the selected markup"/>
                                <Button Content="Assign"
                                        Click="AssignSelectedMarkup_Click"
                                        Padding="8,2"
                                        Margin="0,0,6,4"
                                        IsEnabled="{Binding MarkupTool.HasSelectedMarkup}"
                                        ToolTip="Assign the selected markup to a reviewer"/>
                                <Button Content="Assign Visible"
                                        Click="AssignVisibleMarkups_Click"
                                        Padding="8,2"
                                        Margin="0,0,6,4"
                                        ToolTip="Assign all currently visible markups to a reviewer"/>
                                <Button Content="Approve" Click="ApproveMarkup_Click" Padding="8,2" Margin="0,0,6,4"/>
                                <Button Content="Reject" Click="RejectMarkup_Click" Padding="8,2" Margin="0,0,6,4"/>
                                <Button Content="Resolve" Click="ResolveMarkup_Click" Padding="8,2" Margin="0,0,6,4"/>
                                <Button Content="Resolve Visible" Click="ResolveVisibleMarkups_Click" Padding="8,2" Margin="0,0,6,4"/>
                                <Button Content="Void Visible" Click="VoidVisibleMarkups_Click" Padding="8,2" Margin="0,0,6,4"/>
                                <Button Content="Delete" Click="DeleteComponent_Click" Padding="8,2" Margin="0,0,6,4"/>
                                <Button Content="Clear Filters" Command="{Binding MarkupTool.ClearFiltersCommand}" Padding="8,2" Margin="0,0,6,4"/>
                            </WrapPanel>
                            <Border DockPanel.Dock="Top"
                                    Margin="4,0,4,6"
                                    Padding="8"
                                    Background="#FFF7F7F8"
                                    BorderBrush="#FFD0D7DE"
                                    BorderThickness="1"
                                    Visibility="{Binding MarkupTool.SelectedMarkup, Converter={StaticResource NotNullToVisibilityConverter}}">
                                <StackPanel>
                                    <TextBlock Text="Assignment" FontWeight="Bold" FontSize="11" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding MarkupTool.SelectedMarkupAssignmentSummary}" TextWrapping="Wrap"/>
                                    <TextBlock Margin="0,6,0,0">
                                        <Run Text="Current Assignee: " FontWeight="SemiBold"/>
                                        <Run Text="{Binding MarkupTool.SelectedMarkupAssignedTo}"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                            <Border DockPanel.Dock="Top"
                                    Margin="4,0,4,6"
                                    Padding="8"
                                    Background="#FFF7F7F8"
                                    BorderBrush="#FFD0D7DE"
                                    BorderThickness="1"
                                    Visibility="{Binding MarkupTool.SelectedMarkup, Converter={StaticResource NotNullToVisibilityConverter}}">
                                <StackPanel>
                                    <TextBlock Text="Review Thread" FontWeight="Bold" FontSize="11" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding MarkupTool.SelectedMarkupReplySummary}" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding MarkupTool.SelectedMarkupReplySearchSummary}" Foreground="Gray" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="164" Margin="0,8,0,0">
                                        <ItemsControl ItemsSource="{Binding MarkupTool.SelectedMarkupReplies}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="0,0,0,6" Padding="6" Background="#FFFFFFFF" BorderBrush="#FFD8DEE4" BorderThickness="1">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="#FFFFFFFF"/>
                                                                <Setter Property="BorderBrush" Value="#FFD8DEE4"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding EntryKindKey}" Value="audit">
                                                                        <Setter Property="Background" Value="#FFF4F7FA"/>
                                                                        <Setter Property="BorderBrush" Value="#FFB8C2CC"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding EntryKindKey}" Value="status-audit">
                                                                        <Setter Property="Background" Value="#FFF2F8F2"/>
                                                                        <Setter Property="BorderBrush" Value="#FFB6D4B6"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding EntryKindKey}" Value="assignment-audit">
                                                                        <Setter Property="Background" Value="#FFF9F4EC"/>
                                                                        <Setter Property="BorderBrush" Value="#FFD9C4A5"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <StackPanel>
                                                            <DockPanel Margin="0,0,0,4" LastChildFill="False">
                                                                <Border Padding="6,1"
                                                                        CornerRadius="3"
                                                                        Background="#FFEAF2FF"
                                                                        BorderBrush="#FFBDD3FF"
                                                                        BorderThickness="1"
                                                                        DockPanel.Dock="Left">
                                                                    <Border.Style>
                                                                        <Style TargetType="Border">
                                                                            <Setter Property="Background" Value="#FFEAF2FF"/>
                                                                            <Setter Property="BorderBrush" Value="#FFBDD3FF"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding EntryKindKey}" Value="audit">
                                                                                    <Setter Property="Background" Value="#FFE9EEF3"/>
                                                                                    <Setter Property="BorderBrush" Value="#FFBCC7D2"/>
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding EntryKindKey}" Value="status-audit">
                                                                                    <Setter Property="Background" Value="#FFE7F4E7"/>
                                                                                    <Setter Property="BorderBrush" Value="#FFB1CFAF"/>
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding EntryKindKey}" Value="assignment-audit">
                                                                                    <Setter Property="Background" Value="#FFFCE9D6"/>
                                                                                    <Setter Property="BorderBrush" Value="#FFDDBA88"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Border.Style>
                                                                    <TextBlock Text="{Binding EntryTypeDisplayText}" FontSize="10" FontWeight="SemiBold" Foreground="#FF22303C"/>
                                                                </Border>
                                                                <TextBlock Margin="8,0,0,0" VerticalAlignment="Center">
                                                                    <Run Text="{Binding Author}" FontWeight="SemiBold"/>
                                                                    <Run Text="  "/>
                                                                    <Run Text="{Binding CreatedDisplayText}" Foreground="Gray"/>
                                                                </TextBlock>
                                                            </DockPanel>
                                                            <TextBlock Text="{Binding Text}" TextWrapping="Wrap"/>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </StackPanel>
                            </Border>
                            <Border DockPanel.Dock="Top"
                                    Margin="4,0,4,6"
                                    Padding="8"
                                    Background="#FFF7F7F8"
                                    BorderBrush="#FFD0D7DE"
                                    BorderThickness="1"
                                    Visibility="{Binding MarkupTool.SelectedMarkup, Converter={StaticResource NotNullToVisibilityConverter}}">
                                <StackPanel>
                                    <TextBlock Text="Text Edit" FontWeight="Bold" FontSize="11" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding MarkupTool.SelectedMarkupTextEditSummary}" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding MarkupTool.SelectedMarkupTextShortcutHint}" Foreground="Gray" Margin="0,4,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding MarkupTool.HasTextShortcutHint}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="Current Value" FontWeight="SemiBold" Margin="0,6,0,2">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding MarkupTool.HasSelectedMarkupTextDetails}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="{Binding MarkupTool.SelectedMarkupTextDetails}" TextWrapping="Wrap">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding MarkupTool.HasSelectedMarkupTextDetails}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                            <Border DockPanel.Dock="Top"
                                    Margin="4,0,4,6"
                                    Padding="8"
                                    Background="#FFF7F7F8"
                                    BorderBrush="#FFD0D7DE"
                                    BorderThickness="1"
                                    Visibility="{Binding MarkupTool.SelectedMarkup, Converter={StaticResource NotNullToVisibilityConverter}}">
                                <StackPanel>
                                    <TextBlock Text="Appearance Edit" FontWeight="Bold" FontSize="11" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding MarkupTool.SelectedMarkupAppearanceEditSummary}" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding MarkupTool.SelectedMarkupAppearanceShortcutHint}" Foreground="Gray" Margin="0,4,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding MarkupTool.HasAppearanceShortcutHint}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="Current Values" FontWeight="SemiBold" Margin="0,6,0,2">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding MarkupTool.HasSelectedMarkupAppearanceDetails}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="{Binding MarkupTool.SelectedMarkupAppearanceDetails}" TextWrapping="Wrap">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding MarkupTool.HasSelectedMarkupAppearanceDetails}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                            <Border DockPanel.Dock="Top"
                                    Margin="4,0,4,6"
                                    Padding="8"
                                    Background="#FFF7F7F8"
                                    BorderBrush="#FFD0D7DE"
                                    BorderThickness="1"
                                    Visibility="{Binding MarkupTool.SelectedMarkup, Converter={StaticResource NotNullToVisibilityConverter}}">
                                <StackPanel>
                                    <TextBlock Text="Path Edit" FontWeight="Bold" FontSize="11" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding MarkupTool.SelectedMarkupPathEditSummary}" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding MarkupTool.SelectedMarkupPathShortcutHint}" Foreground="Gray" Margin="0,4,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding MarkupTool.HasPathShortcutHint}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="Current Values" FontWeight="SemiBold" Margin="0,6,0,2">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding MarkupTool.HasSelectedMarkupPathDetails}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="{Binding MarkupTool.SelectedMarkupPathDetails}" TextWrapping="Wrap">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding MarkupTool.HasSelectedMarkupPathDetails}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                            <Border DockPanel.Dock="Top"
                                    Margin="4,0,4,6"
                                    Padding="8"
                                    Background="#FFF7F7F8"
                                    BorderBrush="#FFD0D7DE"
                                    BorderThickness="1"
                                    Visibility="{Binding MarkupTool.SelectedMarkup, Converter={StaticResource NotNullToVisibilityConverter}}">
                                <StackPanel>
                                    <TextBlock Text="Geometry Edit" FontWeight="Bold" FontSize="11" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding MarkupTool.SelectedMarkupGeometryEditSummary}" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding MarkupTool.SelectedMarkupGeometryShortcutHint}" Foreground="Gray" Margin="0,4,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding MarkupTool.HasGeometryShortcutHint}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="Current Values" FontWeight="SemiBold" Margin="0,6,0,2">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding MarkupTool.HasSelectedMarkupGeometryDetails}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="{Binding MarkupTool.SelectedMarkupGeometryDetails}" TextWrapping="Wrap">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding MarkupTool.HasSelectedMarkupGeometryDetails}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                            <Border DockPanel.Dock="Top" Margin="4,0,4,6" Padding="8" Background="#FFF7F7F8" BorderBrush="#FFD0D7DE" BorderThickness="1">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding MarkupTool.HasStructuredSelection}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel>
                                    <TextBlock Text="Structured Annotation" FontWeight="Bold" FontSize="11" Margin="0,0,0,4"/>
                                    <TextBlock Margin="0,0,0,2">
                                        <Run Text="Kind: " FontWeight="SemiBold"/>
                                            <Run Text="{Binding MarkupTool.SelectedMarkupAnnotationKind, Mode=OneWay}"/>
                                    </TextBlock>
                                    <TextBlock Margin="0,0,0,2">
                                        <Run Text="Role: " FontWeight="SemiBold"/>
                                            <Run Text="{Binding MarkupTool.SelectedMarkupAnnotationRole, Mode=OneWay}"/>
                                    </TextBlock>
                                    <TextBlock>
                                        <Run Text="Key: " FontWeight="SemiBold"/>
                                            <Run Text="{Binding MarkupTool.SelectedMarkupAnnotationKey, Mode=OneWay}"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                            <!-- List -->
                            <ListView x:Name="MarkupListView"
                                      ItemsSource="{Binding MarkupTool.FilteredMarkups}"
                                      SelectedItem="{Binding MarkupTool.SelectedMarkup}"
                                                                            SelectionChanged="MarkupListView_SelectionChanged"
                                      MouseDoubleClick="MarkupListView_MouseDoubleClick"
                                      FontSize="11">
                                <ListView.View>
                                    <GridView>
                                                                                <GridViewColumn Header="Sheet" DisplayMemberBinding="{Binding ReviewSheetDisplayText}" Width="132"/>
                                        <GridViewColumn Header="Status" DisplayMemberBinding="{Binding StatusDisplayText}" Width="84"/>
                                        <GridViewColumn Header="Type" DisplayMemberBinding="{Binding TypeDisplayText}" Width="96"/>
                                        <GridViewColumn Header="Label" DisplayMemberBinding="{Binding Metadata.Label}" Width="130"/>
                                        <GridViewColumn Header="Subject" DisplayMemberBinding="{Binding Metadata.Subject}" Width="118"/>
                                        <GridViewColumn Header="Layer" DisplayMemberBinding="{Binding LayerDisplayText}" Width="102"/>
                                        <GridViewColumn Header="Author" DisplayMemberBinding="{Binding Metadata.Author}" Width="92"/>
                                        <GridViewColumn Header="Assignee" DisplayMemberBinding="{Binding AssignedToDisplayText}" Width="96"/>
                                        <GridViewColumn Header="Replies" DisplayMemberBinding="{Binding ReplyCountDisplayText}" Width="52"/>
                                        <GridViewColumn Header="Modified" DisplayMemberBinding="{Binding ModifiedDisplayText}" Width="118"/>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </DockPanel>
                    </TabItem>

                    </TabControl>
                </DockPanel>
            </Border>

            <GridSplitter x:Name="PropertiesGridSplitter"
                          Grid.Column="1"
                          Width="6"
                          Panel.ZIndex="10"
                          Cursor="SizeWE"
                          HorizontalAlignment="Right"
                          VerticalAlignment="Stretch"
                          ResizeDirection="Columns"
                          ResizeBehavior="PreviousAndNext"
                          ShowsPreview="True"
                          Background="#22000000"
                          DragCompleted="PropertiesGridSplitter_DragCompleted"/>

        </Grid>

        <!-- Status Bar -->
        <StatusBar x:Name="AppStatusBar" DockPanel.Dock="Bottom" Height="24">
            <StatusBarItem>
                <TextBlock x:Name="CoordinateText" Text="X: 0.000  Y: 0.000" FontFamily="Consolas" FontSize="11"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock x:Name="ZoomLevelText" Text="Zoom: 100%" FontFamily="Consolas" FontSize="11"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock x:Name="ComponentCountText" Text="Components: 0" FontSize="11"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock x:Name="SelectionCountText" Text="Selected: 0" FontSize="11"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock x:Name="ActiveLayerText" Text="Layer: Default" FontSize="11"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock x:Name="OrthoStatusText" Text="" FontSize="11" Foreground="Gray"/>
            </StatusBarItem>
        </StatusBar>
    </DockPanel>
</Window>
